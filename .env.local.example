# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic AI (server-side only — single key for all users, free during beta)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# WorldTides API
WORLDTIDES_API_KEY=your-worldtides-key

# Web Push VAPID Keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# PostgreSQL direct connection (for auto-migrations at startup)
# Get from: Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Vercel Cron Secret (random string to protect cron endpoints)
CRON_SECRET=your-random-secret-here
